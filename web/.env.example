# ─── Supabase ──────────────────────────────────────────────────────────────────
# Znajdziesz je w: Supabase Dashboard → Settings → API

# Publiczny URL projektu (bez trailing slash)
NEXT_PUBLIC_SUPABASE_URL=https://[YOUR-PROJECT-REF].supabase.co

# Klucz publiczny (anon / publishable key)
NEXT_PUBLIC_SUPABASE_ANON_KEY=[YOUR-ANON-KEY]

# Klucz serwisowy (service_role / secret key) — tylko server-side!
SUPABASE_SERVICE_ROLE_KEY=[YOUR-SERVICE-ROLE-KEY]

# ─── Database (Supabase Pooler) ────────────────────────────────────────────────
# Użyj POOLER (session mode), nie bezpośredniego połączenia.
# Znajdziesz w: Supabase Dashboard → Settings → Database → Connection pooling
# Format: postgresql://postgres.[PROJECT-REF]:[DB-PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres
DATABASE_URL=postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-DB-PASSWORD]@[YOUR-POOLER-HOST]:5432/postgres

# ─── AI (opcjonalne) ──────────────────────────────────────────────────────────
# Google Gemini API key (dla AI asystenta)
GOOGLE_AI_API_KEY=[YOUR-GOOGLE-AI-KEY]
