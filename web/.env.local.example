# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://[PROJECT-ID].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=[ANON-KEY]
SUPABASE_SERVICE_ROLE_KEY=[SERVICE-ROLE-KEY]

# Database (Supabase PostgreSQL — direct connection)
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-ID].supabase.co:5432/postgres

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Email (do powiadomień o feature requests — opcjonalnie Resend lub SMTP)
EMAIL_FROM=noreply@scrooge.app
# Option A: Resend
RESEND_API_KEY=[RESEND-API-KEY]
# Option B: SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=[EMAIL]
SMTP_PASS=[APP-PASSWORD]

# Admin
ADMIN_EMAIL=[ADMIN-EMAIL]

# AI Chat (opcjonalne — użytkownik konfiguruje w ustawieniach)
# Te zmienne są tylko do testów lokalnych, użytkownicy konfigurują klucze API w aplikacji
OPENAI_API_KEY=[OPENAI-KEY]
ANTHROPIC_API_KEY=[ANTHROPIC-KEY]
